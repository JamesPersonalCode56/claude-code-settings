# DeepSeek native API — connection + token + model lineup (self-contained).
# Copy to env/models-deepseek.env (chmod 600) and fill API_KEYS with your real DeepSeek API key.
# Sourced by claude-switch.sh (claude-deepseek) and read by qwen-key-helper.sh.
BASE_URL='https://api.deepseek.com/anthropic'
API_KEYS='sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
ANTHROPIC_MODEL='deepseek-v4-pro[1m]'
ANTHROPIC_DEFAULT_OPUS_MODEL='deepseek-v4-pro[1m]'
ANTHROPIC_DEFAULT_SONNET_MODEL='deepseek-v4-pro[1m]'
ANTHROPIC_DEFAULT_HAIKU_MODEL='deepseek-v4-flash'
CLAUDE_CODE_SUBAGENT_MODEL='deepseek-v4-flash'
CLAUDE_CODE_EFFORT_LEVEL='max'
