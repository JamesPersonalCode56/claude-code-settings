# Claude Code auto-compact tuning — exported as REAL shell env vars.
#
# WHY NOT settings.json: putting CLAUDE_AUTOCOMPACT_PCT_OVERRIDE in the
# settings.json "env" block is silently ignored by the autocompact logic
# (anthropics/claude-code#63186). These must be real environment variables in
# the shell that launches `claude`, and they only apply to NEW sessions.
#
#   CLAUDE_CODE_AUTO_COMPACT_WINDOW : effective context window (tokens) the
#       auto-compact math treats as 100%. Trigger = PCT% x this window.
#       For Anthropic models it is auto-detected; for a CUSTOM endpoint
#       (e.g. Qwen via ANTHROPIC_BASE_URL) Claude Code assumes ~200K and you
#       MUST set this to the model's real context so compaction fires correctly.
#   CLAUDE_AUTOCOMPACT_PCT_OVERRIDE : % of that window at which to compact
#       (1-100). Capped at ~83% internally (a ~13K-token response buffer is
#       reserved), so you can only LOWER the trigger, not raise it past ~83%.

export CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000
export CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=40
