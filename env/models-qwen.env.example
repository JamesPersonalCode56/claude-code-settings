# Qwen (Alibaba Model Studio) — connection + token + model lineup (self-contained).
# Copy to env/models-qwen.env (chmod 600) and fill API_KEYS with your real Qwen token.
# Sourced by claude-switch.sh (claude-qwen) and read by qwen-key-helper.sh / build-settings.mjs.
# Claude Code strips a trailing [1m] before sending the id upstream; [1m] only switches
# Claude Code to a 1M-context window. The four [1m] models are verified 1M-context; kimi has none.
BASE_URL='https://token-plan.ap-southeast-1.maas.aliyuncs.com/apps/anthropic'
API_KEYS='sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
ANTHROPIC_MODEL='deepseek-v4-pro[1m]'
ANTHROPIC_DEFAULT_HAIKU_MODEL='deepseek-v4-flash[1m]'
ANTHROPIC_DEFAULT_SONNET_MODEL='deepseek-v4-pro[1m]'
ANTHROPIC_DEFAULT_FABLE_MODEL='qwen3.7-max[1m]'
ANTHROPIC_DEFAULT_OPUS_MODEL='glm-5.2[1m]'
CLAUDE_CODE_SUBAGENT_MODEL='deepseek-v4-pro[1m]'
ANTHROPIC_CUSTOM_MODEL_OPTION='kimi-k2.7-code'
ANTHROPIC_CUSTOM_MODEL_OPTION_NAME='Kimi K2.7 Code'
ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION='Moonshot coding/agent (256K ctx)'
