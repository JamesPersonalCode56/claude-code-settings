# Safety net — never commit secrets or runtime state, even if copied in by mistake.
.env
vendor/*/.env
# de-vendored claude-switch (now plain files): keep its real secret + runtime state out
vendor/claude-switch/.env
vendor/claude-switch/.omc/
# per-provider claude-switch env files (base url + real token + lineup) — keep out of git; .example variants ARE tracked
env/models-qwen.env
env/models-deepseek.env
.credentials.json
*credentials*
.claude.json
*.key
*.pem
*.token
*token*
*secret*
.*/
# ...but keep project tooling dot-dirs (the broad .*/ above would hide them)
!.github/
!.github/**
*.env.local
# backups produced by setup.sh
*.bak
*.bak-*
# runtime / cache (in case someone copies a whole ~/.claude)
history.jsonl
*stats*.json
*cache*.json
sessions/
projects/
file-history/
shell-snapshots/
paste-cache/
.last-*
